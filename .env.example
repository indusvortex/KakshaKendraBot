# WhatsApp Business API (from Meta Developer Dashboard)
WHATSAPP_TOKEN=your_graph_api_access_token_here
WHATSAPP_PHONE_NUMBER_ID=your_business_phone_number_id_here

# Webhook verification token (set this same value in Meta Dashboard > Webhooks)
VERIFY_TOKEN=my_secure_verify_token

# Groq API key (from console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Optional: phone number for testing (with country code, no +)
TEST_PHONE=919012345678
